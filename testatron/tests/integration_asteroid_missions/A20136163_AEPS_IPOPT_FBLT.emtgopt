#EMTGv9 .emtgopt file version 2

#mission name
mission_name A20136163_AEPS_IPOPT_FBLT
#objective function type
#2: maximum final mass
objective_type 2
#launch window open date (MJD)
launch_window_open_date 61200.0
#flight time bounds (days)
total_flight_time_bounds 700.0 3650.0
#NLP solver type
#0: SNOPT
#1: WORHP
#2: IPOPT
NLP_solver_type 2
#Quiet NLP solver?
quiet_NLP 1
#NLP feasibility tolerance
snopt_feasibility_tolerance 1.0e-8
#NLP optimality tolerance
snopt_optimality_tolerance 1.0e-5
#NLP major iterations
snopt_major_iterations 5000
#NLP max run time (seconds)
snopt_max_run_time 900
#Universe folder
universe_folder ../../universe
#0: static, 1: SPICE, 2: SplineEphem
ephemeris_source 1
#Beginning of the SplineEphem data set
earliestPossibleEpoch 61200.0
#End of the SplineEphem data set
latestPossibleEpoch 67981.0
#phase type
#3: FBLT
mission_type 3
#Propagator type
#1: Integrated propagator
propagatorType 1
#Integrator type
#1: rk8 fixed step
integratorType 1
#integration step size (seconds)
integration_time_step_size 86400
#number of timesteps per phase
num_timesteps 40
#Allow the mass at the beginning of the first journey to vary up to the allowed maximum?
allow_initial_mass_to_vary 1
#maximum possible mass of the spacecraft (kg)
maximum_mass 2500.0
#Reference mass model for the Studio 15 kW AEPS asteroid search.
#The dry-mass floor is inclusive of bus, power, propulsion hardware, payload,
#and non-electric consumables; subsystem library masses remain zero to avoid
#double-counting this system-level estimate.
final_mass_constraint_bounds 1200.0 2500.0
constrain_dry_mass 1
#Treat 1000 kg as installed xenon capacity and hold 10% of deterministic use
#for operations, missed thrust, and residuals.
enable_electric_propellant_tank_constraint 1
maximum_electric_propellant 1000.0
electric_propellant_margin 0.10
#number of thruster systems
number_of_electric_propulsion_systems 1
#percentage of time that engine can operate
engine_duty_cycle 0.9
#power margin (fraction)
power_margin 0.15
#Spacecraft object input type
#0: Assemble from libraries
SpacecraftModelInput 0
#HardwarePath
HardwarePath ../../HardwareModels
#LaunchVehicleLibraryFile
LaunchVehicleLibraryFile default.emtg_launchvehicleopt
#PowerSystemsLibraryFile
PowerSystemsLibraryFile default.emtg_powersystemsopt
#PropulsionSystemsLibraryFile
PropulsionSystemsLibraryFile default.emtg_propulsionsystemopt
#LaunchVehicleKey
LaunchVehicleKey Fixed_Initial_Mass
#PowerSystemKey
PowerSystemKey 15kW_basic
#ElectricPropulsionSystemKey
ElectricPropulsionSystemKey AEPS_PolyFit_HTandHI
#ChemicalPropulsionSystemKey
ChemicalPropulsionSystemKey DefaultChemicalPropulsionSystem
#third body perturbations?
perturb_thirdbody 1
#solar radiation pressure?
perturb_SRP 0
#Override the working directory?
override_working_directory 1
#User-defined working directory
forced_working_directory .
#Create a mission subfolder?
override_mission_subfolder 1
#Mission subfolder
forced_mission_subfolder .
#Shorten output file names?
short_output_file_names 1
#Generate forward-integrated ephemeris?
generate_forward_integrated_ephemeris 1
#SPICE ID of central body for forward integrated ephemeris
forward_integrated_ephemeris_central_body_SPICE_ID 10
#Append control vector to ephemeris output?
append_control_to_ephemeris_output 1
#Close program after completion?
background_mode 1
#which inner loop solver to run?
#3: run NLP using trialX as initial guess
run_inner_loop 3
#Field for taking notes
user_data ("fixture","Earth to asteroid 20136163 using SPICE asteroid ephemeris, IPOPT, and an AEPS-class 15 kW solar electric spacecraft with a 1200 kg inclusive dry-mass floor and 10% xenon reserve.")

BEGIN_JOURNEY

#Journey name
journey_name Earth_to_A20136163
#Journey central body name
journey_central_body Sun_A20136163
#destination list, as indices from the Universe file
destination_list 3 11
#phase type
#3: FBLT
phase_type 3
#Journey wait time bounds (days)
wait_time_bounds 0.0 1826.25
#what are the bounds on the initial impulse for each journey in km/s
initial_impulse_bounds 0.0 5.5
#journey arrival type
#3: low-thrust rendezvous
arrival_type 3
#Journey forced terminal coast (in days)
forced_terminal_coast 14.0
#Which bodies are used for third-body perturbation?
#Expressed as indices in the Universe file
perturbation_bodies 2 4 5 6 7 8

BEGIN_MANEUVER_CONSTRAINT_BLOCK
END_MANEUVER_CONSTRAINT_BLOCK

BEGIN_BOUNDARY_CONSTRAINT_BLOCK
END_BOUNDARY_CONSTRAINT_BLOCK

BEGIN_PHASE_DISTANCE_CONSTRAINT_BLOCK
END_PHASE_DISTANCE_CONSTRAINT_BLOCK

